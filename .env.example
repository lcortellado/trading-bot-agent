# ─────────────────────────────────────────────
#  Crypto Trading Bot — Environment Variables
#  Copy this file to .env and fill in values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────

# App
APP_NAME="Crypto Trading Bot"
APP_VERSION="0.1.0"
DEBUG=false

# Trading mode: "paper" (default) or "testnet"
# "paper" = fully simulated, no network calls for orders
# "testnet" = real calls to testnet.binance.vision
TRADING_MODE=paper

# Binance Testnet credentials
# Get from: https://testnet.binance.vision/  (requires GitHub login)
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
BINANCE_TESTNET_BASE_URL=https://testnet.binance.vision/api/v3
BINANCE_REQUEST_TIMEOUT=10

# Risk parameters
MAX_POSITION_SIZE_PCT=0.02       # 2% of capital per trade
MAX_OPEN_POSITIONS=5
MAX_DAILY_DRAWDOWN_PCT=0.05      # 5% daily drawdown stops trading
DEFAULT_STOP_LOSS_PCT=0.02       # 2% stop loss
DEFAULT_TAKE_PROFIT_PCT=0.04     # 4% take profit (2:1 risk/reward)

# Strategy defaults
DEFAULT_SYMBOL=BTCUSDT
DEFAULT_TIMEFRAME=1h
SMA_SHORT_PERIOD=9
SMA_LONG_PERIOD=21

# Paper trading
PAPER_INITIAL_CAPITAL=10000.0

# ─────────────────────────────────────────────
# AI Agent — ChatGPT (OpenAI) or Claude (Anthropic)
# ─────────────────────────────────────────────
# Provider: anthropic (default) or openai
AI_PROVIDER=anthropic
AI_ENABLED=true
AI_TIMEOUT=15

# Anthropic — https://console.anthropic.com/
AI_API_KEY=
AI_MODEL=claude-haiku-4-5-20251001

# OpenAI (ChatGPT API) — https://platform.openai.com/api-keys
# Use with AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Position monitor — interval (seconds) between SL/TP price checks
POSITION_MONITOR_INTERVAL=30

# Dashboard — max rows kept in memory for /dashboard (oldest dropped)
DASHBOARD_MAX_EVENTS=500

# ─────────────────────────────────────────────
# Automatic trading loop (3Commas-style scheduler)
# ─────────────────────────────────────────────
# Set AUTO_TRADING_ENABLED=true to run a background task that periodically
# fetches candles, runs the configured strategies, optionally asks the AI agent,
# then applies risk checks and places orders (paper or testnet — same as TRADING_MODE).
AUTO_TRADING_ENABLED=false
AUTO_TRADING_INTERVAL_SECONDS=300
AUTO_TRADING_SYMBOLS=BTCUSDT
AUTO_TRADING_TIMEFRAME=1h
# Comma-separated strategy registry keys (see get_available_strategies in sma_crossover.py)
AUTO_TRADING_STRATEGIES=sma_crossover
AUTO_TRADING_USE_AI=true
AUTO_TRADING_SKIP_IF_OPEN=true
AUTO_TRADING_COOLDOWN_SECONDS=3600
AUTO_TRADING_CANDLE_LIMIT=120

# ─────────────────────────────────────────────
# Strategy lab — compare strategies in paper (no real orders)
# ─────────────────────────────────────────────
# Runs in parallel: same candles, each strategy has its own virtual long-only PnL.
# Web UI: /dashboard/lab/  ·  API: GET /api/dashboard/strategy-lab
STRATEGY_LAB_ENABLED=false
STRATEGY_LAB_INTERVAL_SECONDS=300
STRATEGY_LAB_SYMBOLS=BTCUSDT
STRATEGY_LAB_TIMEFRAME=5m
# Registry keys: sma_crossover | sma_5_15 | sma_13_34 (see get_available_strategies)
STRATEGY_LAB_STRATEGIES=sma_crossover,sma_5_15,sma_13_34
STRATEGY_LAB_CANDLE_LIMIT=120
STRATEGY_LAB_NOTIONAL_USD=1000
# TP distance = SL distance * multiplier (e.g. 1.2R)
STRATEGY_LAB_TP_MULTIPLIER=1.2
# Dynamic SL% from volatility, clamped into this range
STRATEGY_LAB_SL_MIN_PCT=0.005
STRATEGY_LAB_SL_MAX_PCT=0.02
# Adds combo_majority lane (majority BUY/SELL across strategies)
STRATEGY_LAB_USE_COMBINED_SIGNALS=true
